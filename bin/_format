#!/usr/bin/env bash

set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/_ci.sh
source "$script_dir/_ci.sh"

log_dir="$(mktemp -d)"
trap 'rm -rf "$log_dir"' EXIT
run_quiet_step "." "stylua" "$log_dir/stylua.output" \
	stylua --check --respect-ignores "."
